# DEEPSEEK_API_KEY: Required for DeepSeek AI parameter parsing.
# Keep this on the server only. Do not expose it as a VITE_* variable.
DEEPSEEK_API_KEY="MY_DEEPSEEK_API_KEY"

# Optional DeepSeek settings.
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-v4-flash"

# AI parse endpoint rate limit. Defaults to 10 requests per IP per 60 seconds.
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX=10

# Number of trusted proxy hops for real client IP detection.
# Use 1 for common single-proxy deployments such as Nginx/Cloud Run.
TRUST_PROXY_HOPS=1

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Optional path to the Blender executable.
# Windows local preview: prefer `npm run dev:local`, which auto-detects blender.exe.
# Linux/ECS: prefer `npm run dev:ecs`, which auto-detects /root/blender-*/blender or blender in PATH.
# BLENDER_PATH="/usr/local/bin/blender"

# Path to your .blend file. Relative paths are resolved from the project root.
BLEND_FILE="param.blend"

# CORS allowed origins (comma separated). Use '*' only for short local testing.
ALLOWED_ORIGINS="https://chromosomeyuxa.github.io,https://www.yuxastudio.top"

# Server port (default 3000)
PORT=3000

# Public backend URL used by the GitHub Pages frontend.
VITE_API_BASE_URL="https://api.yuxastudio.top"
